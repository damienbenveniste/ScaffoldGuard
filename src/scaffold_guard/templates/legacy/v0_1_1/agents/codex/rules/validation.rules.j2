# generated by scaffold-guard; edit scaffold-guard.toml or rerun scaffold-guard compile-rules

prefix_rule(
    pattern = ["scaffold-guard", "check"],
    decision = "allow",
    justification = "Generated ScaffoldGuard policy checks are expected validation.",
    match = ["scaffold-guard check", "scaffold-guard check --path ."],
)

prefix_rule(
    pattern = ["scaffold-guard", "inspect-diff"],
    decision = "allow",
    justification = "Diff inspection is expected validation before claiming completion.",
    match = ["scaffold-guard inspect-diff", "scaffold-guard inspect-diff --path ."],
)

prefix_rule(
    pattern = ["scaffold-guard", "validate"],
    decision = "allow",
    justification = "Generated project validation is expected before claiming completion.",
    match = ["scaffold-guard validate", "scaffold-guard validate --quick"],
)

prefix_rule(
    pattern = ["uv", "run", "scaffold-guard", "check"],
    decision = "allow",
    justification = "Repository-local ScaffoldGuard checks are expected validation.",
    match = ["uv run scaffold-guard check"],
)

{% if use_python %}
{% if use_ruff %}
prefix_rule(
    pattern = ["uv", "run", "ruff", "format", "--check", "{% if profile == "monorepo" %}packages/python{% else %}.{% endif %}"],
    decision = "allow",
    justification = "Ruff format checks are expected read-only validation.",
    match = ["uv run ruff format --check {% if profile == "monorepo" %}packages/python{% else %}.{% endif %}"],
)

prefix_rule(
    pattern = ["uv", "run", "ruff", "check", "{% if profile == "monorepo" %}packages/python{% else %}.{% endif %}"],
    decision = "allow",
    justification = "Ruff lint checks are expected validation.",
    match = ["uv run ruff check {% if profile == "monorepo" %}packages/python{% else %}.{% endif %}"],
    not_match = ["uv run ruff check --fix {% if profile == "monorepo" %}packages/python{% else %}.{% endif %}"],
)

{% endif %}
{% if use_mypy %}
prefix_rule(
    pattern = ["uv", "run", "mypy", {% if profile == "monorepo" %}"packages/python/src"{% else %}"src"{% endif %}],
    decision = "allow",
    justification = "mypy checks are expected validation.",
    match = ["uv run mypy {% if profile == "monorepo" %}packages/python/src packages/python/tests packages/python/examples{% else %}src tests examples{% endif %}"],
)

{% endif %}
{% if use_pyright %}
prefix_rule(
    pattern = ["uv", "run", "pyright"],
    decision = "allow",
    justification = "Pyright checks are expected validation.",
    match = ["uv run pyright"],
)

{% endif %}
prefix_rule(
    pattern = ["uv", "run", "pytest", {% if profile == "monorepo" %}"packages/python/tests"{% else %}"tests"{% endif %}],
    decision = "allow",
    justification = "pytest commands under the generated test directory are expected validation.",
    match = ["uv run pytest {% if profile == "monorepo" %}packages/python/tests{% else %}tests{% endif %}"],
)

{% if docs_enabled == "true" %}
prefix_rule(
    pattern = ["uv", "run", "mkdocs", "build", "--strict"],
    decision = "allow",
    justification = "Strict MkDocs builds are expected documentation validation.",
    match = ["uv run mkdocs build --strict"],
)

{% endif %}
{% endif %}
{% if use_typescript %}
{% if use_biome %}
prefix_rule(
    pattern = ["npm", "run", "{% if profile == "monorepo" %}ts:format:check{% else %}format:check{% endif %}"],
    decision = "allow",
    justification = "Biome format checks are expected validation.",
    match = ["npm run {% if profile == "monorepo" %}ts:format:check{% else %}format:check{% endif %}"],
)

prefix_rule(
    pattern = ["npm", "run", "{% if profile == "monorepo" %}ts:lint{% else %}lint{% endif %}"],
    decision = "allow",
    justification = "Biome lint checks are expected validation.",
    match = ["npm run {% if profile == "monorepo" %}ts:lint{% else %}lint{% endif %}"],
)

{% endif %}
prefix_rule(
    pattern = ["npm", "run", "{% if profile == "monorepo" %}ts:typecheck{% else %}typecheck{% endif %}"],
    decision = "allow",
    justification = "TypeScript compiler checks are expected validation.",
    match = ["npm run {% if profile == "monorepo" %}ts:typecheck{% else %}typecheck{% endif %}"],
)

{% if use_vitest %}
{% if profile == "monorepo" %}
prefix_rule(
    pattern = ["npm", "run", "ts:test"],
    decision = "allow",
    justification = "Vitest checks are expected validation.",
    match = ["npm run ts:test"],
)
{% else %}
prefix_rule(
    pattern = ["npm", "test"],
    decision = "allow",
    justification = "Vitest checks are expected validation.",
    match = ["npm test"],
)
{% endif %}

{% endif %}
prefix_rule(
    pattern = ["npm", "run", "{% if profile == "monorepo" %}ts:build{% else %}build{% endif %}"],
    decision = "allow",
    justification = "Generated TypeScript builds are expected validation.",
    match = ["npm run {% if profile == "monorepo" %}ts:build{% else %}build{% endif %}"],
)

{% if use_vitest %}
prefix_rule(
    pattern = ["npm", "run", "{% if profile == "monorepo" %}ts:coverage{% else %}coverage{% endif %}"],
    decision = "allow",
    justification = "Coverage checks are expected validation.",
    match = ["npm run {% if profile == "monorepo" %}ts:coverage{% else %}coverage{% endif %}"],
)
{% endif %}
{% endif %}
