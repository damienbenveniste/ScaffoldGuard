name: CI

on:
  push:
    branches: [main]
  pull_request:

permissions:
  contents: read

jobs:
  guardrails:
    name: ScaffoldGuard
    runs-on: ubuntu-latest
    steps:
      - name: Check out repository
        uses: actions/checkout@v7.0.0

      - name: Install uv
        uses: astral-sh/setup-uv@v8.3.0

      - name: Install ScaffoldGuard
        run: uv tool install scaffold-guard

      - name: Agent policy check
        run: scaffold-guard check
