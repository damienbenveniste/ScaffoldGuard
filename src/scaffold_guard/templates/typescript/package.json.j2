{
  "name": "{{ typescript_package_name }}",
  "version": "0.1.0",
  "description": "{{ project_slug }} generated by scaffold-guard.",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
{%- if use_biome %}
    "format": "biome format --write .",
    "format:check": "biome ci .",
    "lint": "biome lint .",
{%- endif %}
    "typecheck": "tsc --noEmit",
{%- if use_vitest %}
    "test": "vitest run",
    "coverage": "vitest run --coverage",
{%- endif %}
    "build": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
{%- if use_biome %}
    "@biomejs/biome": "^2.5.0",
{%- endif %}
{%- if use_vitest %}
    "@vitest/coverage-v8": "^4.0.0",
{%- endif %}
    "typescript": "^5.9.0"{% if use_vitest %},
    "vitest": "^4.0.0"
{%- endif %}
  }
}
