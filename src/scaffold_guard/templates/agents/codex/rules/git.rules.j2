# generated by scaffold-guard; edit scaffold-guard.toml or rerun scaffold-guard compile-rules

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Inspecting repository status is safe and expected.",
    match = ["git status", "git status --short"],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Inspecting local diffs is safe and expected.",
    match = ["git diff", "git diff --check", "git diff --stat"],
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "Reading commit history is safe and expected.",
    match = ["git log --oneline -5"],
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "forbidden",
    justification = "Use uv run scaffold-guard publish for audited commits; raw git commit depends on unavailable approvals in approval-free sessions.",
    match = ["git commit -m update"],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "forbidden",
    justification = "Use uv run scaffold-guard publish for audited pushes; raw git push depends on unavailable approvals in approval-free sessions.",
    match = ["git push origin feature"],
)

prefix_rule(
    pattern = ["uv", "run", "scaffold-guard", "upgrade"],
    decision = "allow",
    justification = "Repo-local ScaffoldGuard upgrade preview is safe; applying the plan requires explicit user intent and review.",
    match = [
        "uv run scaffold-guard upgrade",
        "uv run scaffold-guard upgrade --apply",
    ],
)

prefix_rule(
    pattern = ["uv", "run", "scaffold-guard", "publish"],
    decision = "allow",
    justification = "Publishing through ScaffoldGuard runs validation, refuses mixed scope, and commits only an explicit reviewed selection.",
    match = ["uv run scaffold-guard publish --message update --all"],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard local work. Use a reviewed, targeted revert instead.",
    match = ["git reset --hard"],
)

prefix_rule(
    pattern = ["git", "clean", "-fdx"],
    decision = "forbidden",
    justification = "Do not bulk-delete untracked files. Remove reviewed generated artifacts by path.",
    match = ["git clean -fdx"],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Do not recursively remove paths without a narrower reviewed command.",
    match = ["rm -rf build"],
)
