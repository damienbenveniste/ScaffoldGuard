[project]
name = "{{ project_slug }}"
package = "{{ package_name }}"
profile = "monorepo"
python_min = "{{ python_min }}"
coverage_fail_under = {{ coverage }}
ci = "{{ ci_provider }}"

[agents]
codex = {{ codex_enabled }}
claude = {{ claude_enabled }}
cursor = {{ cursor_enabled }}

[features]
docs = false
github_actions = {{ github_actions_enabled }}
gitlab_ci = {{ gitlab_ci_enabled }}
mkdocs = false
python = true
typescript = true

[tools]
ruff = {{ ruff_enabled }}
ruff_mode = "{{ ruff_mode }}"
mypy = {{ mypy_enabled }}
pyright = {{ pyright_enabled }}
python_typecheck = "{{ python_typecheck_mode }}"
python_typechecker = "{{ python_typechecker }}"
typescript = true
typescript_strict = {{ typescript_strict_enabled }}
biome = {{ biome_enabled }}
vitest = {{ vitest_enabled }}

[policy]
forbid_type_ignore = {{ mypy_enabled }}
forbid_pyright_ignore = {{ pyright_enabled }}
forbid_noqa = {{ ruff_enabled }}
forbid_any = true
forbid_dict_str_any = true
forbid_shell_true = true
require_tests_for_src_changes = true
require_docs_for_public_api_changes = true
require_lockfile_for_dependency_changes = true

[validation]
quick = [
{% if use_ruff %}
  "uv run ruff format --check packages/python",
  "uv run ruff check packages/python",
{% endif %}
  "uv run pytest packages/python/tests/unit",
{% if use_biome %}
  "npm run ts:format:check",
  "npm run ts:lint",
{% endif %}
  "npm run ts:typecheck",
{% if use_vitest %}
  "npm run ts:test",
{% endif %}
  "scaffold-guard check"
]
full = [
{% if use_ruff %}
  "uv run ruff format --check packages/python",
  "uv run ruff check packages/python",
{% endif %}
{% if use_mypy %}
  "uv run mypy packages/python/src packages/python/tests packages/python/examples",
{% endif %}
{% if use_pyright %}
  "uv run pyright",
{% endif %}
  "uv run pytest packages/python/tests --cov={{ package_name }} --cov-report=term-missing --cov-fail-under={{ coverage }}",
{% if use_biome %}
  "npm run ts:format:check",
  "npm run ts:lint",
{% endif %}
  "npm run ts:typecheck",
{% if use_vitest %}
  "npm run ts:test",
{% endif %}
  "npm run ts:build",
{% if use_vitest %}
  "npm run ts:coverage",
{% endif %}
  "scaffold-guard check"
]
