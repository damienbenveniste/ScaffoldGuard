import { describe, expect, it } from "vitest";

import { greet } from "../src/index.js";

describe("greet", () => {
  it("returns a greeting", () => {
    expect(greet("TypeScript")).toBe("Hello, TypeScript!");
  });

  it("falls back for blank names", () => {
    expect(greet("   ")).toBe("Hello, World!");
  });
});
