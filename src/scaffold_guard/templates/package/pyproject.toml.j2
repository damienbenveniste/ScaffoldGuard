[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_slug }} generated by scaffold-guard."
readme = "README.md"
requires-python = ">={{ python_min }}"
license = "{{ license }}"
dependencies = []

[dependency-groups]
dev = [
    "scaffold-guard>=0.1.0",
    "mkdocs>=1.6.0",
    "mkdocs-material>=9.6.0",
{% if use_mypy %}
    "mypy>=1.17.0",
{% endif %}
    "pytest>=8.4.0",
    "pytest-cov>=6.2.0",
{% if use_pyright %}
    "pyright>=1.1.400",
{% endif %}
{% if use_ruff %}
    "ruff>=0.12.0",
{% endif %}
]

[build-system]
requires = ["hatchling>=1.27.0"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

{% if use_ruff %}
[tool.ruff]
target-version = "py313"
line-length = 100
src = ["src", "tests", "examples"]

[tool.ruff.lint]
select = [
{% if use_ruff_strict %}
    "ANN",
    "ARG",
{% endif %}
    "B",
    "C4",
{% if use_ruff_strict %}
    "C90",
{% endif %}
    "E",
    "F",
    "I",
    "N",
    "PERF",
    "PIE",
{% if use_ruff_strict %}
    "PL",
{% endif %}
    "PT",
    "PTH",
    "RET",
    "RUF",
    "S",
    "SIM",
    "TRY",
    "UP",
]
ignore = [
    "TRY003",
]

{% if use_ruff_strict %}
[tool.ruff.lint.mccabe]
max-complexity = 10

[tool.ruff.lint.pylint]
max-args = 5
max-branches = 12
max-returns = 6
max-statements = 60

{% endif %}
[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = ["S101"]
{% endif %}

{% if use_mypy %}
[tool.mypy]
python_version = "3.13"
{% if use_python_typecheck_strict %}
strict = true
{% else %}
check_untyped_defs = true
no_implicit_optional = true
{% endif %}
warn_unreachable = true
pretty = true
show_error_codes = true
{% endif %}

[tool.pytest.ini_options]
minversion = "8.4"
testpaths = ["tests"]
pythonpath = ["src"]
addopts = [
    "--strict-config",
    "--strict-markers",
]

[tool.coverage.run]
branch = true
source = ["{{ package_name }}"]

[tool.coverage.report]
fail_under = {{ coverage }}
show_missing = true
skip_covered = true
exclude_also = [
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
]
