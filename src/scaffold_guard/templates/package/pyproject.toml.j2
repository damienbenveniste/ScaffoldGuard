[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_slug }} generated by scaffold-guard."
readme = "README.md"
requires-python = ">={{ python_min }}"
license = "{{ license }}"
dependencies = []

[dependency-groups]
dev = [
    "scaffold-guard>=0.1.0",
    "mkdocs>=1.6.0",
    "mkdocs-material>=9.6.0",
{% if use_mypy %}
    "mypy>=1.17.0",
{% endif %}
    "pytest>=8.4.0",
    "pytest-cov>=6.2.0",
{% if use_pyright %}
    "pyright>=1.1.400",
{% endif %}
{% if use_ruff %}
    "ruff>=0.12.0",
{% endif %}
]

[build-system]
requires = ["hatchling>=1.27.0"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

{% if use_ruff %}
[tool.ruff]
target-version = "py313"
line-length = 100
src = ["src", "tests", "examples"]

[tool.ruff.lint]
select = [
{{ ruff_select_rules_toml }}
]
{% if ruff_has_ignores %}

ignore = [
{{ ruff_ignore_rules_toml }}
]
{% endif %}
{% if ruff_uses_mccabe %}

[tool.ruff.lint.mccabe]
max-complexity = 10
{% endif %}
{% if ruff_uses_pylint %}

[tool.ruff.lint.pylint]
max-args = 5
max-branches = 12
max-returns = 6
max-statements = 60
{% endif %}
{% if ruff_allows_test_asserts %}

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = ["S101"]
{% endif %}
{% endif %}

{% if use_mypy %}
[tool.mypy]
python_version = "3.13"
{% if mypy_preset == "strict" %}
strict = true
warn_unreachable = true
pretty = true
show_error_codes = true
{% else %}
warn_unused_configs = true
disallow_untyped_defs = true
no_implicit_optional = true
warn_return_any = true
pretty = true
show_error_codes = true
{% endif %}
{% endif %}

[tool.pytest.ini_options]
minversion = "8.4"
testpaths = ["tests"]
pythonpath = ["src"]
addopts = [
    "--strict-config",
    "--strict-markers",
]

[tool.coverage.run]
branch = true
source = ["{{ package_name }}"]

[tool.coverage.report]
fail_under = {{ coverage }}
show_missing = true
skip_covered = true
exclude_also = [
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
]
