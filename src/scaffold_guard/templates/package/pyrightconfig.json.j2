{
  "include": ["src", "tests", "examples"],
  "exclude": ["**/__pycache__", ".venv", ".mypy_cache", ".pytest_cache", ".ruff_cache"],
  "pythonVersion": "3.13",
  "typeCheckingMode": "{{ pyright_type_checking_mode }}",
  "venvPath": ".",
  "venv": ".venv",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["src"]
    }
  ],
  "reportMissingTypeStubs": "warning"
}
