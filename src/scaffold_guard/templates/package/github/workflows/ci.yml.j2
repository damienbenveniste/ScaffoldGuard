name: CI

on:
  push:
    branches: [main]
  pull_request:

permissions:
  contents: read

jobs:
  python:
    name: Python {% raw %}${{ matrix.python-version }}{% endraw %}
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        python-version: ["3.13", "3.14"]

    steps:
      - name: Check out repository
        uses: actions/checkout@v7.0.0

      - name: Install uv
        uses: astral-sh/setup-uv@v8.3.0

      - name: Set up Python
        uses: actions/setup-python@v6.3.0
        with:
          python-version: {% raw %}${{ matrix.python-version }}{% endraw %}

      - name: Sync workspace
        run: uv sync --all-groups --python {% raw %}${{ matrix.python-version }}{% endraw %}

      - name: Agent policy check
        run: uv run scaffold-guard check

{% if use_ruff %}
      - name: Check formatting
        run: uv run ruff format --check .

      - name: Lint
        run: uv run ruff check .

{% endif %}
{% if use_mypy %}
      - name: Type check with mypy
        run: uv run mypy src tests examples

{% endif %}
{% if use_pyright %}
      - name: Type check with Pyright
        run: uv run pyright

{% endif %}
      - name: Build docs
        run: uv run mkdocs build --strict

      - name: Test
        run: >
          uv run pytest tests
          --cov={{ package_name }}
          --cov-report=term-missing
          --cov-fail-under={{ coverage }}
